<UserControl x:Class="GymManagementSystem.WPF.Views.ScheduledClass.ScheduledClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Scheduled classes"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <!--<Button Grid.Column="1"
                        Content="Generate new"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding GenerateScheduledClass}"/>-->
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding ScheduledClasses}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"/>

                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding Date}"/>

                        <DataGridTextColumn Header="Start from"
                                            Binding="{Binding StartFrom}"/>

                        <DataGridTextColumn Header="End time"
                                            Binding="{Binding StartTo}"/>

                        <DataGridTextColumn Header="Max people"
                                            Binding="{Binding MaxPeople}"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding IsActive}"/>

                        <DataGridTemplateColumn Header="Details" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenScheduledClassDetails,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="InformationOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>

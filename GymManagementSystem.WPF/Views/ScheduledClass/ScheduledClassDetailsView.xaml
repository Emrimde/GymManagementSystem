<UserControl x:Class="GymManagementSystem.WPF.Views.ScheduledClass.ScheduledClassDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ScheduledClass"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" Content="{Binding SidebarView}"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="{DynamicResource PrimaryColor}">
            <Run Text="Scheduled class:"/>
            <Run Text="{Binding ScheduledClass.Date}"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Duration:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                        <Run Text="{Binding ScheduledClass.StartFrom}"/>
                        <Run Text="-"/>
                        <Run Text="{Binding ScheduledClass.StartTo}"/>
                    </TextBlock>
                    
                    
                </StackPanel>
                    <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="Max people"/>
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="{Binding ScheduledClass.MaxPeople}"/>
                
                    </StackPanel>
                    <StackPanel  Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="Status"/>
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="{Binding ScheduledClass.IsCancelled}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="Updated At"/>
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="{Binding ScheduledClass.UpdatedAt}"/>
                    </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="Created at"/>
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" Text="{Binding ScheduledClass.CreatedAt}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Foreground="{DynamicResource PrimaryColor}" Content="Add client to classes" Command="{Binding OpenClassBookingAddView}" CommandParameter="{Binding ScheduledClass.Id}"/>
                    
                </StackPanel>

            </StackPanel>
        </Grid>

    </Grid>
</UserControl>

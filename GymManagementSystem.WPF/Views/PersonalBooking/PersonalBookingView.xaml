<UserControl x:Class="GymManagementSystem.WPF.Views.PersonalBooking.PersonalBookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0"
                Background="#2F3038"
                Padding="8">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <!-- CONTENT -->
        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Personal Trainings"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="ADD TRAINING"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding OpenPersonalTrainingAddViewCommand}" CommandParameter="{Binding ClientId}"/>
            </Grid>

            <!-- GRID -->
            <materialDesign:Card Grid.Row="1"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding PersonalBookings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}"
                          >

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding Date}"/>

                        <DataGridTextColumn Header="Time"
                                            Binding="{Binding StartEndTime}"/>

                        <DataGridTextColumn Header="Trainer"
                                            Binding="{Binding TrainerFullName}"/>

                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding BookingStatus}"/>

                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price}"/>

                        <!-- EDIT -->
                        <DataGridTemplateColumn Header="Edit" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenEditPersonalBookingCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding PersonalBookingId}">
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <!-- DELETE -->
                        <DataGridTemplateColumn Header="Delete" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.DeletePersonalBookingCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding PersonalBookingId}">
                                        <materialDesign:PackIcon Kind="DeleteOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>
        </Grid>
    </Grid>
</UserControl>

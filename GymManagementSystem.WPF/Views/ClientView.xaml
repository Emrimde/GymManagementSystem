<UserControl x:Class="GymManagementSystem.WPF.Views.ClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000" Background="{StaticResource BackgoundColor}">
    <UserControl.InputBindings>
        <KeyBinding Key="Enter" Command="{Binding SearchClientsCommand}"/>
    </UserControl.InputBindings>
        
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock 
        Grid.Column="0"
        Text="Gym Clients" 
        FontSize="30" FontWeight="Bold" Foreground="#EEEEEE" 
                    HorizontalAlignment="left"
        
        VerticalAlignment="Center"
                    Width="200" Margin="40,0,0,0"/>

                <Button 
        Grid.Column="1"
        Content="Add Client"
        Width="150"
        Height="30"
        HorizontalAlignment="Right" Margin="0,0,40,0" Command="{Binding OpenAddClientView}" />
            </Grid>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
                <Button Content="Search:" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0" Command="{Binding SearchClientsCommand}"/>
                <TextBox Width="200" Height="25" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" />
            </StackPanel>


            <Border Grid.Row="2" Background="#2B2B2B">
                <DataGrid Style="{DynamicResource DataGridStyle1}" RowStyle="{DynamicResource DataGridRowStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" ItemsSource="{Binding Clients}" x:Name="datagrid" CanUserAddRows="False"
                  AutoGenerateColumns="false">



                    <DataGrid.Columns>
                        <DataGridTextColumn Header="First name" Binding="{Binding FirstName}"/>
                        <DataGridTextColumn Header="Last name" Binding="{Binding LastName}"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                        <DataGridTextColumn Header="PhoneNumber" Binding="{Binding PhoneNumber}"/>
                        <DataGridTextColumn Header="DateOfBirth" Binding="{Binding DateOfBirth}"/>
                        <DataGridTextColumn Header="Street" Binding="{Binding Street}"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}"/>

                        <DataGridTemplateColumn Header="Details" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="40" Height="25" Background="#4CAF50" Foreground="White" FontSize="10"
                                        Command="{Binding DataContext.      OpenClientDetailsCommand,                   RelativeSource=         { RelativeSource                   AncestorType=DataGrid}}"
                                        CommandParameter="{Binding Id}">
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Edit/Delete" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button  
                                    Width="40" 
                                    Height="25" 
                                    Background="#4CAF50" 
                                    Foreground="White" FontSize="10"
                                   Command="{Binding DataContext.OpenEditClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}"
                                     >
                                            <fa:ImageAwesome Icon="Edit" Width="10" Height="25" Foreground="White"/>
                                        </Button>

                                        <Button
                                     Width="40" 
                                    Height="25" FontSize="10"
                                    Background="#F44336" 
                                    Foreground="White"
                                    Command="{Binding DataContext.DeleteClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding}" >
                                            <fa:ImageAwesome Icon="Trash" Width="10" Height="25" Foreground="White"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
                <ListBox ItemsSource="{Binding VisiblePages}"
         SelectedItem="{Binding SelectedPage}"
         Height="Auto"
         Width="Auto" Background="{DynamicResource BackgoundColor}" Foreground="White">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
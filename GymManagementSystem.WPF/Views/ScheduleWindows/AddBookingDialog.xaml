<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.AddBookingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ScheduleWindows"
        xmlns:input="clr-namespace:System.Windows.Controls;assembly=DotNetProjects.Input.Toolkit"
        mc:Ignorable="d"
        Title="AddBookingDialog" Height="450" Width="800">
    <StackPanel Margin="20">

        <TextBlock Text="Client:" />
        
        <input:AutoCompleteBox
Width="250"
MinimumPrefixLength="1"
ItemsSource="{Binding Clients}"
SelectedItem="{Binding SelectedClient}"
ValueMemberPath="FullName"
FilterMode="None"
VerticalContentAlignment="Center" FontSize="20"
TextChanged="AutoCompleteBox_TextChanged" SelectionChanged="AutoCompleteBox_SelectionChanged"
            
            />
        <TextBlock Text="Start:" Margin="0 10 0 0"/>
        <TextBox Text="{Binding StartTime}"/>

        <TextBlock Text="End:" Margin="0 10 0 0"/>
        <TextBox Text="{Binding EndTime}"/>

        <Button Content="Save"
                Margin="0 20 0 0"
                Command="{Binding SaveCommand}"/>

    </StackPanel>
</Window>

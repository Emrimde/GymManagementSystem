<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.AddingDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Time off" Height="400" Width="380"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Reason:" Foreground="{DynamicResource SecondColor}"   />
        <TextBox Text="{Binding Reason}" Margin="0 5 0 10" FontSize="17" Height="30" VerticalContentAlignment="Center"/>

        <TextBlock Text="Date:" Foreground="{DynamicResource SecondColor}"/>
        <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}" FontSize="17" 
                    Margin="0 5 0 10"/>

        <TextBlock Text="Start time:" Foreground="{DynamicResource SecondColor}" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedStartSlot, Mode=TwoWay}"
                  Margin="0 5 0 10"/>

        <TextBlock Text="End time:" Foreground="{DynamicResource SecondColor}" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedEndSlot, Mode=TwoWay}"
                  Margin="0 5 0 20"/>

        <Button Content="Save"
                Command="{Binding SaveCommand}"
                Width="80"/>
    </StackPanel>
</Window>

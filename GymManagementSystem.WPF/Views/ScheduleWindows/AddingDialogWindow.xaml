<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.AddingDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Time off" Height="250" Width="380"
        WindowStartupLocation="CenterScreen" >

    <StackPanel Margin="20">

        <TextBlock Text="Reason:" />
        <TextBox Text="{Binding Subject}" Margin="0 5 0 10"/>

        <TextBlock Text="Date:" />
        <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                    Margin="0 5 0 10"/>

        <TextBlock Text="Start time:" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedStartSlot, Mode=TwoWay}"
                  Margin="0 5 0 10"/>

        <TextBlock Text="End time:" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedEndSlot, Mode=TwoWay}"
                  Margin="0 5 0 20"/>

        <Button Content="Save"
                Command="{Binding SaveCommand}"
                Width="80"/>
    </StackPanel>
</Window>

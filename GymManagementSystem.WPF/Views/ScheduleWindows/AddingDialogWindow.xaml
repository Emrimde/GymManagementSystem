<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.AddingDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Appointment" Height="250" Width="380"
        WindowStartupLocation="CenterScreen" >

    <StackPanel Margin="20" VerticalAlignment="Center">

        <TextBlock Text="Subject:" />
        <TextBox Text="{Binding Subject}" />

        <TextBlock Text="Start Time:" />
        <TextBox Text="{Binding StartTime}" />

        <TextBlock Text="End Time:" />
        <TextBox Text="{Binding EndTime}" />

        <Button Content="Save"
                Width="120"
                HorizontalAlignment="Center"
                Command="{Binding SaveCommand}" />
    </StackPanel>
</Window>

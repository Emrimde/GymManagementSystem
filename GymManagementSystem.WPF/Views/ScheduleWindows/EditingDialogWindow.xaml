<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.EditingDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit time off"
        Height="420"
        Width="380"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20">

        <TextBlock Text="Reason:" />
        <TextBox Text="{Binding Reason}"
                 Margin="0 5 0 10"
                 Height="30"
                 VerticalContentAlignment="Center"/>

        <TextBlock Text="Date:" />
        <DatePicker SelectedDate="{Binding SelectedDate}"
                    Margin="0 5 0 10"/>

        <TextBlock Text="Start time:" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedStartSlot}"
                  Margin="0 5 0 10"/>

        <TextBlock Text="End time:" />
        <ComboBox Width="120"
                  ItemsSource="{Binding TimeSlots}"
                  SelectedItem="{Binding SelectedEndSlot}"
                  Margin="0 5 0 20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Save"
                    Width="80"
                    Margin="5"
                    Command="{Binding SaveCommand}" />
            <Button Content="Delete"
                    Width="80"
                    Margin="5"
                    Command="{Binding DeleteCommand}" />
        </StackPanel>

    </StackPanel>
</Window>

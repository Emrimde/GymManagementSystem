<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.EditingDialogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ScheduleWindows"
        mc:Ignorable="d"
        Title="Edit event" Height="450" Width="800">
    <StackPanel Margin="20" VerticalAlignment="Center" >

        <TextBlock Text="Subject:" />
        <TextBox Text="{Binding Subject}" />

        <TextBlock Text="Start Time:" />
        <TextBox Text="{Binding StartTime}" />

        <TextBlock Text="End Time:" />
        <TextBox Text="{Binding EndTime}" />

        <Button Content="Save"
              Width="120"
              HorizontalAlignment="Center"
              Command="{Binding SaveCommand}" />
    </StackPanel>
</Window>

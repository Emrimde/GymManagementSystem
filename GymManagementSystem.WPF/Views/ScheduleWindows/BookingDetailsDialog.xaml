<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.BookingDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ScheduleWindows"
        mc:Ignorable="d"
        Title="BookingDetailsDialog" Height="450" Width="800" >
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConv"/>
    </Window.Resources>
    <StackPanel Margin="20">
        <TextBlock Text="Client:" />
        <TextBlock Text="{Binding ClientName}" />

        <TextBlock Text="Start time:" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding Start}"/>

        <TextBlock Text="End time:" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding End}"/>
        
        <TextBlock Text="Status :" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding Statuss}"/>
        
        <TextBlock Text="Price :" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding Price}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 20 0 ">
            <Button Content="Client didn't come" 
                      Command="{Binding DeleteCommand}"   Visibility="{Binding IsNotPaid , Converter={StaticResource BooleanToVisibilityConv}}"/>
            <Button Content="Client paid" Visibility="{Binding IsNotPaid , Converter={StaticResource BooleanToVisibilityConv}}"
          Command="{Binding SetStatusToPaidCommand}" Margin="20 0 0 0 "/>
            
        </StackPanel>
    </StackPanel>
</Window>

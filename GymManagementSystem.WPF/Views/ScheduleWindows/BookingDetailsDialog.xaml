<Window x:Class="GymManagementSystem.WPF.Views.ScheduleWindows.BookingDetailsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ScheduleWindows"
        mc:Ignorable="d"
        Title="BookingDetailsDialog" Height="450" Width="800">
    <StackPanel Margin="20">
        <TextBlock Text="Client:" />
        <TextBlock Text="{Binding ClientName}" />

        <TextBlock Text="Start time:" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding Start}"/>

        <TextBlock Text="End time:" Margin="0 10 0 0"/>
        <TextBlock Text="{Binding End}"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 30 0 0">
            <Button Content="Cancel Booking" Margin="5" Command="{Binding CancelCommand}"/>
            <Button Content="Close" Margin="5" Command="{Binding CloseCommand}"/>
        </StackPanel>
    </StackPanel>
</Window>

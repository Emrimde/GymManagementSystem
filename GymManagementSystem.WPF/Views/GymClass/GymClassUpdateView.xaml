<UserControl x:Class="GymManagementSystem.WPF.Views.GymClass.GymClassUpdateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,24,0,32"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryColor}">
                <Run Text="Edit "/>
                <Run Text="{Binding Form.Name}"/>
            </TextBlock>

            <materialDesign:Card Grid.Row="1"
                                 Margin="48,0"
                                 Padding="32"
                                 UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Name"
                                       FontSize="23"
                                       Foreground="{StaticResource PrimaryColor}"/>
                            <TextBox Height="40"
                                     FontSize="17"
                                     Foreground="{StaticResource PrimaryColor}"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding Form.Name,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Margin="0,0,0,16">
                            <TextBlock Text="Days of week"
                                       FontSize="23"
                                       Foreground="{StaticResource PrimaryColor}"/>

                            <ListBox ItemsSource="{Binding DaysOfWeekItems}"
                                     HorizontalAlignment="Stretch">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Day}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="Start hour"
                                       FontSize="23"
                                       Foreground="{StaticResource PrimaryColor}"/>
                            <TextBox Height="40"
                                     FontSize="17"
                                     Foreground="{StaticResource PrimaryColor}"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding Form.StartHour,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Column="1" Margin="32,0,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16">
                            <TextBlock Text="Trainer"
                                       FontSize="23"
                                       Foreground="{StaticResource PrimaryColor}"/>
                            <ComboBox Height="60"
                                      HorizontalAlignment="Stretch"
                                      ItemsSource="{Binding TrainerContracts}"
                                      DisplayMemberPath="FullName"
                                      SelectedItem="{Binding SelectedTrainerContract}"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      Foreground="{StaticResource PrimaryColor}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Max people"
                                       FontSize="23"
                                       Foreground="{StaticResource PrimaryColor}"/>
                            <TextBox Height="40"
                                     FontSize="17"
                                     Foreground="{StaticResource PrimaryColor}"
                                     HorizontalAlignment="Stretch"
                                     Text="{Binding Form.MaxPeople,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                </Grid>
            </materialDesign:Card>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,32,48,24">

                <Button Content="Update"
                        Height="40"
                        MinWidth="160"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding EditGymClassCommand}"/>

                <Button Content="Cancel"
                        Height="40"
                        MinWidth="120"
                        Margin="12,0,0,0"
                        Command="{Binding CancelCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

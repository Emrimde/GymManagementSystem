<UserControl x:Class="GymManagementSystem.WPF.Views.GymClass.GymClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.GymClass"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock 
        Grid.Column="0"
        Text="Gym Classes" 
        FontSize="30" FontWeight="Bold" Foreground="#EEEEEE" 
                    HorizontalAlignment="left"
        
        VerticalAlignment="Center"
                    Width="200" Margin="40,0,0,0"/>

                <Button 
        Grid.Column="1"
        Content="Add Gym class"
        Width="150"
        Height="30"
        HorizontalAlignment="Right" Margin="0,0,40,0" Command="{Binding OpenAddGymClassCommand}" />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal">
                <ComboBox  ItemsSource="{Binding StatusFilters}" SelectedValue="{Binding SelectedStatusFilter}" SelectedValuePath="Value"
                           DisplayMemberPath="Label" Width="100" Foreground="{StaticResource PrimaryColor}" 
                           />

            </StackPanel>
            <Border Grid.Row="2" Background="#2B2B2B">
                <DataGrid Style="{DynamicResource DataGridStyle1}" RowStyle="{DynamicResource DataGridRowStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" ItemsSource="{Binding GymClasses}" x:Name="datagrid" CanUserAddRows="False"
                  AutoGenerateColumns="false">



                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Start time" Binding="{Binding StartHour}"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}"/>
                        <DataGridTextColumn Header="End time" Binding="{Binding EndTime}"/>
                        <DataGridTextColumn Header="Max People" Binding="{Binding MaxPeople}"/>
                        <DataGridTextColumn Header="Days" Binding="{Binding Days}"/>
                        <DataGridTextColumn Header="Created At" Binding="{Binding CreatedAt}"/>
                        <DataGridTextColumn Header="Updated At" Binding="{Binding UpdatedAt}"/>


                        <DataGridTemplateColumn Header="Details" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Button Width="40" Height="25" Background="#4CAF50" Foreground="White" FontSize="10"
Command="{Binding DataContext.OpenScheduledClassesViewCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
CommandParameter="{Binding Id}" Visibility="{Binding IsActive ,Converter={StaticResource BoolToVisibilityConverter}}" >
                                        <fa:ImageAwesome Icon="InfoCircle" Width="10" Height="25" Foreground="White"/>
                                    </Button>


                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>



                        <DataGridTemplateColumn Header="Edit / Delete" Width="150" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button Visibility="{Binding IsActive ,Converter={StaticResource BoolToVisibilityConverter}}"
                                    Width="40" 
                                    Height="25" 
                                    Background="#4CAF50" 
                                    Foreground="White" FontSize="10"
                                   Command="{Binding DataContext.OpenEditGymClassCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}"
                                     >
                                            <fa:ImageAwesome Icon="Edit" Width="10" Height="25" Foreground="White"/>
                                        </Button>

                                       <Button Visibility="{Binding IsActive ,Converter={StaticResource BoolToVisibilityConverter}}"
                                     Width="40" 
                                    Height="25" FontSize="10"
                                    Background="#F44336" 
                                    Foreground="White"
                                    Command="{Binding DataContext.DeleteGymClassCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                    CommandParameter="{Binding Id}" >
                                            <fa:ImageAwesome Icon="Trash" Width="10" Height="25" Foreground="White"/>
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Activate" Width="150" >
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>

                                    <Button  Visibility="{Binding CanActivate, Converter={StaticResource BoolToVisibilityConverter}}" Width="40" Height="25" Background="#4CAF50" Foreground="White" FontSize="10"
Command="{Binding DataContext.ActivateGymClassCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
CommandParameter="{Binding Id}">
                                        <fa:ImageAwesome Icon="InfoCircle" Width="10" Height="25" Foreground="White"/>
                                    </Button>


                                </DataTemplate>

                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
        </Grid>
    </Grid>
</UserControl>

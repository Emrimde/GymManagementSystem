<UserControl x:Class="GymManagementSystem.WPF.Views.GymClass.GymClassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Gym Classes"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Add gym class"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding OpenAddGymClassCommand}"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        Margin="0,0,0,16">

                <ComboBox Width="160"
                          ItemsSource="{Binding StatusFilters}"
                          SelectedValue="{Binding SelectedStatusFilter}"
                          SelectedValuePath="Value"
                          DisplayMemberPath="Label"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Foreground="{StaticResource PrimaryColor}"
                          materialDesign:HintAssist.Hint="Status"/>
            </StackPanel>

            <materialDesign:Card Grid.Row="2"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding GymClasses}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                        <DataGridTextColumn Header="Start time" Binding="{Binding StartHour}"/>
                        <DataGridTextColumn Header="Duration" Binding="{Binding Duration}"/>
                        <DataGridTextColumn Header="End time" Binding="{Binding EndTime}"/>
                        <DataGridTextColumn Header="Max people" Binding="{Binding MaxPeople}"/>
                        <DataGridTextColumn Header="Days" Binding="{Binding Days}"/>
                        <DataGridTextColumn Header="Created at" Binding="{Binding CreatedAt}"/>
                        <DataGridTextColumn Header="Updated at" Binding="{Binding UpdatedAt}"/>

                        <DataGridTemplateColumn Header="Details" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.OpenScheduledClassesViewCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="InformationOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Edit" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.OpenEditGymClassCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Delete" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Visibility="{Binding IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.DeleteGymClassCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="Delete"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Activate" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Visibility="{Binding CanActivate, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding DataContext.ActivateGymClassCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="CheckCircleOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>

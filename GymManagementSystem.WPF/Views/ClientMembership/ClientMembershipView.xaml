<UserControl x:Class="GymManagementSystem.WPF.Views.ClientMembership.ClientMembershipView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#2F3038"
                Padding="8">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center">
                    <Run Text="Membership history – "/>
                    <Run Text="{Binding Client.FullName}"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Content="RETURN"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding ReturnToClientDetailsViewCommand}"/>
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding ClientMemberships}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Start date"
                                            Binding="{Binding StartDate}"/>

                        <DataGridTextColumn Header="End date"
                                            Binding="{Binding EndDate}"/>

                        <DataGridTextColumn Header="Requested date"
                                            Binding="{Binding RequestedDate}"/>

                        <DataGridTextColumn Header="Membership name"
                                            Binding="{Binding Name}"/>

                        <DataGridTextColumn Header="Membership type"
                                            Binding="{Binding MembershipType}"/>

                        <DataGridTemplateColumn Header="Details" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenClientMembershipDetails,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="InformationOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>
            </materialDesign:Card>

            <Grid Grid.Row="2" Height="16"/>

        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.ClientMembership.ClientMembershipAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:GymManagementSystem.WPF.Converters"
             Background="{DynamicResource BackgoundColor}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center">

                <materialDesign:Card Padding="32"
                                     Width="420"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4">

                    <StackPanel>

                        <TextBlock FontSize="26"
                                   FontWeight="SemiBold"
                                   TextAlignment="Center"
                                   Margin="0,0,0,24"
                                   Foreground="{DynamicResource PrimaryColor}">
                            <Run Text="Add membership for "/>
                            <Run Text="{Binding Client.FullName}"/>
                        </TextBlock>

                        <StackPanel Margin="0,0,0,24">

                            <TextBlock Text="Membership"
                                       FontSize="16"
                                       FontWeight="Medium"
                                       Margin="0,0,0,8"
                                       Foreground="{DynamicResource PrimaryColor}"/>

                            <ComboBox Height="40"
                                      TextElement.Foreground="{DynamicResource PrimaryColor}"
                                      ItemsSource="{Binding MembershipSelectItem}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding SelectedMembership, Mode=TwoWay}" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
            HorizontalAlignment="Center">
                            <Button Content="Add membership"
            Style="{StaticResource MaterialDesignFlatButton}"
            Command="{Binding AddClientMembershipCommand}"/>

                            <Button Content="Cancel"
            Margin="0,0,12,0"
            Command="{Binding CancelCommand}"/>

                        </StackPanel>


                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

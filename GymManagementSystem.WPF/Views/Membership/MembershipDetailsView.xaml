<UserControl x:Class="GymManagementSystem.WPF.Views.Membership.MembershipDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <UserControl.Resources>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,24,0,16"/>
        </Style>

        <Style x:Key="VerticalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="HorizontalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="32">

                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,24"
                           Text="{Binding Membership.Name}"/>

                <materialDesign:Card Padding="24"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="Cash" Foreground="{StaticResource PrimaryColor}"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Price"/>
                                <TextBlock Text="{Binding Membership.Price}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="CalendarClock"
                                                     Style="{StaticResource HorizontalItem}" Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Class booking days in advance"/>
                                <TextBlock Text="{Binding Membership.ClassBookingDaysInAdvanceCount}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="AccountMultiplePlus"
                                                     Style="{StaticResource HorizontalItem}" Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Free friend entries per month"/>
                                <TextBlock Text="{Binding Membership.FreeFriendEntryCountPerMonth}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="Dumbbell" Foreground="{StaticResource PrimaryColor}"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Free personal trainings / 6 months"/>
                                <TextBlock Text="{Binding Membership.FreePersonalTrainingSessions}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="CardAccountDetails"
                                                     Style="{StaticResource HorizontalItem}" Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Text="Membership type"/>
                                <TextBlock Text="{Binding Membership.MembershipType}"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,12"/>

                        <StackPanel Orientation="Vertical">

                            <Button Content="Price history"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,0,8"
                                    Command="{Binding OpenMembershipPricesHistory}"/>

                            <Button Content="Membership features"  Margin="0,0,0,8"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Command="{Binding OpenMembershipFeaturesViewCommand}"/>

                            <Button Content="Add membership feature"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,0,8"
                                    Command="{Binding OpenAddMembershipFeatureViewCommand}"/>

                            <Button Content="Add new price"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,0,8"
                                    Command="{Binding OpenAddMembershipPriceCommand}"/>
                        </StackPanel>

                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.Membership.MembershipAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Membership"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="30" Foreground="{StaticResource SecondColor}" Text="Add new membership" />
            <Grid Grid.Row="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Name" Foreground="White"/>
                        <TextBox Text="{Binding MembershipAddRequest.Name}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Price" Foreground="White"/>
                        <TextBox Text="{Binding MembershipAddRequest.Price}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"  Width="150"/>
                    </StackPanel>
                    
                    
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    
                    
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <CheckBox Content="Is for trainer only?" FontSize="25" Foreground="White" IsChecked="{Binding MembershipAddRequest.IsTrainerOnly}"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <ComboBox Text="Membership type" FontSize="25" Foreground="White" ItemsSource="{Binding MembershipTypes}" SelectedItem="{Binding SelectedMembershipType}"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Row="2" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Add Membership" Command="{Binding AddMembershipCommand }"/>
                <Button Content="Cancel"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.TrainerContract.TrainerContractDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>

        <Style x:Key="VerticalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="HorizontalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="32">

                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,24">
                    <Run Text="{Binding TrainerContract.FirstName}"/>
                    <Run Text="{Binding TrainerContract.LastName}"/>
                    <Run Text=" — details"/>
                </TextBlock>

                <materialDesign:Card Padding="24"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4">

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="Email"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Email"/>
                                    <TextBlock Text="{Binding TrainerContract.Email}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="Phone"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Phone number"/>
                                    <TextBlock Text="{Binding TrainerContract.PhoneNumber}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="Percent"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Club commission"/>
                                    <TextBlock Text="{Binding TrainerContract.ClubCommissionPercent}"/>
                                </StackPanel>
                            </StackPanel>

                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    Margin="32,0,0,0">

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="CalendarRange"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Valid from / to"/>
                                    <TextBlock Text="{Binding TrainerContract.Valid}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="FileDocumentOutline"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Contract type"/>
                                    <TextBlock Text="{Binding TrainerContract.ContractType}"/>
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                                <materialDesign:PackIcon Kind="AccountTie"
                                                         Style="{StaticResource HorizontalItem}"
                                                         Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold" Text="Trainer type"/>
                                    <TextBlock Text="{Binding TrainerContract.TrainerType}"/>
                                </StackPanel>
                            </StackPanel>

                            <Separator Margin="0,8"/>

                            <StackPanel Orientation="Vertical">

                                <Button Content="Show schedule"
                                        Width="180"
                                        Margin="0,0,0,8"
                                        Command="{Binding OpenTrainerScheduleCommand}"
                                        CommandParameter="{Binding TrainerContract.Id}"
                                        Visibility="{Binding TrainerContract.CanShowBooking, Converter={StaticResource BoolToVisibilityConverter}}"/>

                                <Button Content="Show Rates"
                                        Width="180"
                                        Margin="0,0,0,8"
                                        Command="{Binding OpenTrainerRatesCommand}"
                                        CommandParameter="{Binding TrainerContract.Id}"/>
                                
                                <Button Content="Set new password"
                                        Width="180"
                                        Margin="0,0,0,8"
                                        Command="{Binding OpenSetNewPasswordViewCommand}"
                                        
                                        />

                                <Button Content="Terminate"
                                        Width="180"
                                        Command="{Binding GenerateTerminationCommand}"
                                        Visibility="{Binding TrainerContract.CanTerminate, Converter={StaticResource BoolToVisibilityConverter}}"/>

                            </StackPanel>

                        </StackPanel>
                    </Grid>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

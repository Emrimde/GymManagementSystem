<UserControl x:Class="GymManagementSystem.WPF.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,24,0,32"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryColor}"
                       Text="General settings"/>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto">

                <materialDesign:Card Margin="48,0"
                                     Padding="32"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,24">
                                <TextBlock Text="Gym name"
                                           FontSize="15"
                                           Foreground="{StaticResource PrimaryColor}"/>
                                <TextBox Height="40"
                                         FontSize="15"
                                         Foreground="{StaticResource PrimaryColor}"
                                         Text="{Binding GeneralGymDetailsUpdateRequest.GymName,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="16,0,0,24">
                                <TextBlock Text="Contact number"
                                           FontSize="15"
                                           Foreground="{StaticResource PrimaryColor}"/>
                                <TextBox Height="40"
                                         FontSize="15"
                                         Foreground="{StaticResource PrimaryColor}"
                                         Text="{Binding GeneralGymDetailsUpdateRequest.ContactNumber,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,16,24">
                                <TextBlock Text="Address"
                                           FontSize="15"
                                           Foreground="{StaticResource PrimaryColor}"/>
                                <TextBox Height="40"
                                         FontSize="15"
                                         Foreground="{StaticResource PrimaryColor}"
                                         Text="{Binding GeneralGymDetailsUpdateRequest.Address,
                                                        UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="16,0,0,24">
                                <TextBlock Text="Logo"
                                           FontSize="15"
                                           Foreground="{StaticResource PrimaryColor}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Choose logo"
                                            Height="40"
                                            MinWidth="160"
                                            Style="{StaticResource MaterialDesignOutlinedButton}"
                                            Command="{Binding PickLogoCommand}"/>
                                    <Image Source="{Binding LogoPreview}"
                                           Height="40"
                                           Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2">
                            <TextBlock Text="About us"
                                       FontSize="15"
                                       Foreground="{StaticResource PrimaryColor}"
                                       Margin="0,0,0,8"/>

                            <TextBox Height="300"
                                     FontSize="15"
                                     Foreground="{StaticResource PrimaryColor}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalAlignment="Stretch"
                                     BorderThickness="1.5"
                                     BorderBrush="{StaticResource PrimaryColor}"
                                     Padding="16"
                                     
                                     Text="{Binding GeneralGymDetailsUpdateRequest.AboutUs,
                                                    UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                    </Grid>
                </materialDesign:Card>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,32,48,24">

                <Button Content="Save changes"
                        Height="40"
                        MinWidth="180"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding SaveGeneralSettingsCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

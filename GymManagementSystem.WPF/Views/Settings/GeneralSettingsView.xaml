<UserControl x:Class="GymManagementSystem.WPF.Views.Settings.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Settings"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <StackPanel Grid.Column="1" Orientation="Vertical">
            <TextBlock 
                Text="General Settings" 
                FontSize="30" 
                FontWeight="Bold" 
                Foreground="#EEEEEE" 
                HorizontalAlignment="Center"
                Margin="0,20,0,40"/>
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
                        Text="Gym Name:" 
                        FontSize="20" 
                        FontWeight="SemiBold" 
                        Foreground="#EEEEEE" 
                        VerticalAlignment="Center"
                        Margin="20,0,10,0"/>
                        <TextBox Width="200" Text="{Binding GeneralGymDetails.GymName}"> 

                        </TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
    Text="Contact number:" 
    FontSize="20" 
    FontWeight="SemiBold" 
    Foreground="#EEEEEE" 
    VerticalAlignment="Center"
    Margin="20,0,10,0"/>
                        <TextBox Width="200" Text="{Binding GeneralGymDetails.ContactNumber}">

                        </TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
                            Text="Address" 
                            FontSize="20" 
                            FontWeight="SemiBold" 
                            Foreground="#EEEEEE" 
                            VerticalAlignment="Center"
                            Margin="20,0,10,0"/>
                        <TextBox Width="200"  Text="{Binding GeneralGymDetails.Address}">

                        </TextBox>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
                        Text="Background color" 
                        FontSize="20" 
                        FontWeight="SemiBold" 
                        Foreground="#EEEEEE" 
                        VerticalAlignment="Center"
                        Margin="20,0,10,0"/>
                        <xctk:ColorPicker SelectedColor="{Binding GeneralGymDetails.BackgroundColor}" Width="100" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
                            Text="Primary Color" 
                            FontSize="20" 
                            FontWeight="SemiBold" 
                            Foreground="#EEEEEE" 
                            VerticalAlignment="Center"
                            Margin="20,0,10,0"/>
                        <xctk:ColorPicker SelectedColor="{Binding GeneralGymDetails.PrimaryColor}" Width="100" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock 
                            Text="Second Color" 
                            FontSize="20" 
                            FontWeight="SemiBold" 
                            Foreground="#EEEEEE" 
                            VerticalAlignment="Center"
                            Margin="20,0,10,0"/>
                        <xctk:ColorPicker SelectedColor="{Binding GeneralGymDetails.SecondColor}" Width="100" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <StackPanel>
                <Button Content="Save Changes" Command="{Binding SaveGeneralSettingsCommand }" Width="150" Height="40" HorizontalAlignment="Center" Margin="0,20,0,0"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>

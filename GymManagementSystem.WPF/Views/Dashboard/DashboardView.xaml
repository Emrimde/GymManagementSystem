<UserControl x:Class="GymManagementSystem.WPF.Views.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:oxy="clr-namespace:OxyPlot.Wpf;assembly=OxyPlot.Wpf"
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Dashboard"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="1000">

    <!-- ================= STYLES ================= -->
    <UserControl.Resources>

        <Style x:Key="KpiCardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="KpiTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>

        <Style x:Key="KpiValueStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

    </UserControl.Resources>

    <Grid Background="#1E1E1E">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#252525">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock
                Text="Dashboard"
                FontSize="32"
                FontWeight="Bold"
                Foreground="White"/>

            <UniformGrid Grid.Row="1" Columns="4" Margin="0,20,0,20">

                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Active clients"
                                   Style="{StaticResource KpiTitleStyle}"/>
                        <TextBlock Text="{Binding DashboardKPI.ActiveMemberships}"
                                   Style="{StaticResource KpiValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Today's visits"
                                   Style="{StaticResource KpiTitleStyle}"/>
                        <TextBlock Text="{Binding DashboardKPI.TotalVisitsToday}"
                                   Style="{StaticResource KpiValueStyle}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource KpiCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Today's new memberships"
                                   Style="{StaticResource KpiTitleStyle}"/>
                        <TextBlock Text="{Binding DashboardKPI.TodayClientMemberships}"
                                   Style="{StaticResource KpiValueStyle}"/>
                    </StackPanel>
                </Border>

         

            </UniformGrid>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Border Style="{StaticResource KpiCardStyle}">
                    <oxy:PlotView Model="{Binding VisitsModel}" Background="{DynamicResource BackgoundColor}" />
                </Border>

                <Border Grid.Row="1" Style="{StaticResource KpiCardStyle}">
                    <oxy:PlotView Model="{Binding ClientMemberships}" Background="{DynamicResource BackgoundColor}"/>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

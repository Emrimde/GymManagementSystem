<UserControl x:Class="GymManagementSystem.WPF.Views.Staff.StaffView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#2F3038"
                Padding="8">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Staff"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="ADD PERSON"
                        Command="{Binding OpenStaffAddView}"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Height="40"
                        Padding="24,0"/>
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="16"
                                 Margin="0,0,0,16"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <ComboBox Width="160"
                              ItemsSource="{Binding StatusFilters}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedIsActive}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Status"
                              Foreground="White"/>

                    <ComboBox Width="180"
                              Margin="16,0,0,0"
                              ItemsSource="{Binding StaffFilterTypes}"
                              SelectedItem="{Binding SelectedStaffFilterType}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Role"
                              Foreground="White"/>

                    <TextBox Width="240"
                             Margin="16,0,0,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             materialDesign:HintAssist.Hint="Search staff"
                             Foreground="White">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter"
                                        Command="{Binding SearchStaffCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Content="SEARCH"
                            Margin="16,0,0,0"
                            Height="40"
                            Command="{Binding SearchStaffCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding People}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="First name" Binding="{Binding FirstName}"/>
                        <DataGridTextColumn Header="Last name" Binding="{Binding LastName}"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}"/>
                        <DataGridTextColumn Header="Role" Binding="{Binding Role}"/>
                        <DataGridTextColumn Header="Created" Binding="{Binding CreatedAt}"/>

                        <DataGridTemplateColumn Header="Details" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenPersonDetailsCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding}">
                                        <materialDesign:PackIcon Kind="InformationOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Edit" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                                            Command="{Binding DataContext.OpenEditPersonCommand,
                                                              RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="Pencil"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

        </Grid>
    </Grid>
</UserControl>

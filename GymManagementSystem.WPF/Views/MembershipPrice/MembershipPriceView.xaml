<UserControl x:Class="GymManagementSystem.WPF.Views.MembershipPrice.MembershipPriceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Membership prices history"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{StaticResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
                        Content="Update membership price"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Command="{Binding OpenAddMembershipPriceViewCommand}"/>
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding MembershipPrices}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Price"
                                            Binding="{Binding Price}"/>

                        <DataGridTextColumn Header="Valid from"
                                            Binding="{Binding ValidFromLabel}"/>

                        <DataGridTextColumn Header="Valid to"
                                            Binding="{Binding ValidToLabel}"/>

                        <DataGridTextColumn Header="Label price"
                                            Binding="{Binding LabelPrice}"/>
                    </DataGrid.Columns>

                </DataGrid>
            </materialDesign:Card>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">

                <Button Content="Return"
                        Height="40"
                        MinWidth="120"
                        Command="{Binding ReturnCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.MembershipPrice.MembershipPriceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.MembershipPrice"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="1*"/>
                <RowDefinition Height="6*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock 
     Grid.Column="0"
     Text="Gym Clients" 
     FontSize="30" FontWeight="Bold" Foreground="#EEEEEE" 
                 HorizontalAlignment="left"
     
     VerticalAlignment="Center"
                 Width="200" Margin="40,0,0,0"/>

                <Button 
     Grid.Column="1"
     Content="Add Client"
     Width="150"
     Height="30"
     HorizontalAlignment="Right" Margin="0,0,40,0" Command="{Binding OpenAddClientView}" />
            </Grid>
            <Border Grid.Row="2" Background="#2B2B2B">
                <DataGrid Style="{DynamicResource DataGridStyle1}" RowStyle="{DynamicResource DataGridRowStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" ItemsSource="{Binding MembershipPrices}" x:Name="datagrid" CanUserAddRows="False"
               AutoGenerateColumns="false">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}"/>
                        <DataGridTextColumn Header="Valid From" Binding="{Binding ValidFromLabel}"/>
                        <DataGridTextColumn Header="Valid To:" Binding="{Binding ValidToLabel}"/>
                        <DataGridTextColumn Header="Label Price: " Binding="{Binding LabelPrice}"/>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
            <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.MembershipPrice.MembershipPriceAddViewModel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="0,24,0,32"
                       HorizontalAlignment="Center"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource PrimaryColor}">
                <Run Text="Add new price for "/>
                <Run Text="{Binding Membership.MembershipName}"/>
            </TextBlock>

            <materialDesign:Card Grid.Row="1"
                                 Margin="48,0"
                                 Padding="32"
                                 UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4"
                                 VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Center">

                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Price"
                                   FontSize="23"
                                   Foreground="{StaticResource PrimaryColor}"/>
                        <TextBox Height="40"
                                 Width="200"
                                 FontSize="17"
                                 Foreground="{StaticResource PrimaryColor}"
                                 Text="{Binding MembershipPriceAdd.Price,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"
                                 ToolTip="{Binding (Validation.Errors)[0].ErrorContent,
                                                   RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Label price (optional)"
                                   FontSize="23"
                                   Foreground="{StaticResource PrimaryColor}"/>
                        <TextBox Height="40"
                                 Width="240"
                                 FontSize="17"
                                 Foreground="{StaticResource PrimaryColor}"
                                 Text="{Binding MembershipPriceAdd.LabelPrice,
                                                UpdateSourceTrigger=PropertyChanged,
                                                ValidatesOnNotifyDataErrors=True}"
                                 ToolTip="{Binding (Validation.Errors)[0].ErrorContent,
                                                   RelativeSource={RelativeSource Self}}"/>
                    </StackPanel>

                </StackPanel>
            </materialDesign:Card>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,32,48,24">

                <Button Content="Add membership price"
                        Height="40"
                        MinWidth="200"
                        Style="{StaticResource MaterialDesignFlatButton}"
                        Command="{Binding AddMembershipPriceCommand}"/>

                <Button Content="Cancel"
                        Height="40"
                        MinWidth="120"
                        Margin="12,0,0,0"
                        Command="{Binding ReturnToMembershipDetailsCommand}"/>
            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

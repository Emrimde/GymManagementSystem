<UserControl x:Class="GymManagementSystem.WPF.Views.Trainer.TrainerAddView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Trainer"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock Margin="0,20,0,0" HorizontalAlignment="Center" FontSize="30" Foreground="{StaticResource SecondColor}" Text="Add new trainer" />
            <Grid Grid.Row="1" >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="First name" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.FirstName}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0" Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Last name" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.LastName}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"  Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Email" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.Email}" VerticalContentAlignment="Center" FontSize="20" Margin="47,0,0,0"  Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Phone Number" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.PhoneNumber}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"  Width="150"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Street" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.Street}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"  Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="City" Foreground="White"/>
                        <TextBox Text="{Binding TrainerAddRequest.City}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"  Width="150"/>
                    </StackPanel>
                    <StackPanel Margin="0,10,0,0" HorizontalAlignment="Center" Orientation="Horizontal">
                        <TextBlock FontSize="25" Text="Date of Birth" Foreground="White"/>
                        <DatePicker SelectedDate="{Binding TrainerAddRequest.DateOfBirth}" VerticalContentAlignment="Center" FontSize="20" Margin="10,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
            <StackPanel Grid.Row="2" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Content="Add trainer" Command="{Binding AddTrainerCommand }"/>
                <Button Content="Cancel"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

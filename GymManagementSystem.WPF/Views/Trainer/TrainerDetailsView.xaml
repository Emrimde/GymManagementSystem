<UserControl x:Class="GymManagementSystem.WPF.Views.Trainer.TrainerDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Trainer"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" Content="{Binding SidebarView}"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="{DynamicResource PrimaryColor}">
            <Run Text="{Binding Trainer.FirstName}"/>
            <Run Text="{Binding Trainer.LastName}"/>
            <Run Text=": details"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Email:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                    <Run Text="{Binding Trainer.Email}"/>
                    </TextBlock>
    
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock Text="Phone number" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock Text="{Binding Trainer.PhoneNumber}" VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Created at:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                    <Run Text="{Binding Trainer.CreatedAt}"/>

                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Updated at:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
     <Run Text="{Binding Trainer.UpdatedAt}"/>

                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="Show schedule" Width="150"  Command="{Binding OpenTrainerScheduleCommand}" CommandParameter="{Binding Trainer.Id}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>

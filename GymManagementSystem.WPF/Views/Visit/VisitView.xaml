<UserControl x:Class="GymManagementSystem.WPF.Views.Visit.VisitView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#2F3038"
                Padding="8">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center">
                    <Run Text="{Binding ClientName.FullName}"/>
                    <Run Text=" – Last visits"/>
                </TextBlock>

                <Button Grid.Column="1"
                        Content="RETURN"
                        Height="40"
                        Padding="24,0"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding ReturnCommand}"/>
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding Visits}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Visit date"
                                            Binding="{Binding VisitDate}"/>

                        <DataGridTextColumn Header="Visit source"
                                            Binding="{Binding VisitSource}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <Grid Grid.Row="2" Height="16"/>
        </Grid>
    </Grid>
</UserControl>

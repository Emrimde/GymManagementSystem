<Window x:Class="GymManagementSystem.WPF.Views.Visit.CustomDialogs.FreeFriendArrivalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Visit.CustomDialogs"
        mc:Ignorable="d " Background="{StaticResource BackgoundColor}"
        Title="FreeFriendArrivalDialog" Height="200" Width="550">
    <StackPanel Margin="20">
        <TextBlock Text="Guest name" Margin="0,0,0,8" Foreground="{StaticResource PrimaryColor}"/>
        <TextBox x:Name="InputBox" Width="250" Margin="0,0,0,12" Foreground="{StaticResource PrimaryColor}"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,8,0" Click="Ok_Click"/>
            <Button Content="Cancel" Width="85" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>

<UserControl x:Class="GymManagementSystem.WPF.Views.MembershipFeature.MembershipFeatureView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.MembershipFeature"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="200"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="#2B2B2B">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="2*"/>
                <RowDefinition Height="7*"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock 
Grid.Column="0"
Text="Membership features" 
FontSize="30" FontWeight="Bold" Foreground="#EEEEEE" 
            HorizontalAlignment="left"

VerticalAlignment="Center"
            Width="Auto" Margin="40,0,0,0"/>

                <Button 
Grid.Column="1"
Content="Add membership feature"
Width="auto"
Height="30"
HorizontalAlignment="Right" Margin="0,0,40,0" Command="{Binding OpenAddMembershipFeatureCommand}" />


            </Grid>
            <Border Grid.Row="1" Background="#2B2B2B">
                <DataGrid Style="{DynamicResource DataGridStyle1}" RowStyle="{DynamicResource DataGridRowStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" ItemsSource="{Binding MembershipFeatures}" x:Name="datagrid" CanUserAddRows="False"
          AutoGenerateColumns="false">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Benefit Desciption:" Binding="{Binding BenefitDesciption}"/>
                        <DataGridTextColumn Header="Benefit Frequency: " Binding="{Binding BenefitFrequency}"/>
                        <DataGridTextColumn Header="Period" Binding="{Binding Period}"/>


                        <DataGridTemplateColumn Header="Edit/Delete" Width="150">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Button  
                            Width="40" 
                            Height="25" 
                            Background="#4CAF50" 
                            Foreground="White" FontSize="10"
                           Command="{Binding DataContext.OpenEditClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                            CommandParameter="{Binding}"
                             >
                                        </Button>

                                        <Button
                             Width="40" 
                            Height="25" FontSize="10"
                            Background="#F44336" 
                            Foreground="White"
                            Command="{Binding DataContext.DeleteClientCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                            CommandParameter="{Binding}" >
                                        </Button>
                                    </StackPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>

                </DataGrid>

            </Border>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" >
                <Button Content="Previous" Width="100" Margin="10,0" Command="{Binding PreviousPageCommand}"/>
                <TextBlock Text="{Binding CurrentPageDisplay}" FontSize="16" VerticalAlignment="Center" Foreground="White"/>
                <Button Content="Next" Width="100" Margin="10,0" />

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

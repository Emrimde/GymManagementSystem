<UserControl x:Class="GymManagementSystem.WPF.Views.Employee.EmployeeDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Employee"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" Content="{Binding SidebarView}"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="{DynamicResource PrimaryColor}">
        <Run Text="{Binding Employee.FirstName}"/>
        <Run Text="{Binding Employee.LastName}"/>
        <Run Text=": details"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Phone number: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                <Run Text="{Binding Employee.PhoneNumber}"/>

                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Visibility="{Binding Person.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                    <TextBlock Text="Role "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20" Text="{Binding Employee.Role}"/>

                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Address"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                    <Run Text="{Binding Employee.City}"/>
                    <Run Text="st."/>
                    <Run Text="{Binding Employee.Street}"/>
                    </TextBlock>

                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="Status "  Foreground="{DynamicResource PrimaryColor}" FontSize="20" />
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Text="{Binding Client.Status}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

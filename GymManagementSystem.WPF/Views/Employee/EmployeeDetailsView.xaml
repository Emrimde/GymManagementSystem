<UserControl x:Class="GymManagementSystem.WPF.Views.Employee.EmployeeDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{StaticResource BackgoundColor}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>

        <Style x:Key="VerticalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="HorizontalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}"/>

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">

            <StackPanel Margin="32">

                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,24">
                    <Run Text="{Binding Employee.FirstName}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding Employee.LastName}"/>
                    <Run Text=" — details"/>
                </TextBlock>

                <materialDesign:Card Padding="24"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="Phone"
                                                     Style="{StaticResource HorizontalItem}"
                                                     Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Phone number"/>
                                <TextBlock Text="{Binding Employee.PhoneNumber}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Style="{StaticResource VerticalItem}"
                                    Visibility="{Binding Employee.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="AccountBadge"
                                                     Style="{StaticResource HorizontalItem}"
                                                     Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Role"/>
                                <TextBlock Text="{Binding Employee.Role}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="HomeMapMarker"
                                                     Style="{StaticResource HorizontalItem}"
                                                     Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Address"/>
                                <TextBlock>
                                    <Run Text="{Binding Employee.Street}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding Employee.City}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="CalendarRange"
                                                     Style="{StaticResource HorizontalItem}"
                                                     Foreground="{StaticResource PrimaryColor}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Contract valid"/>
                                <TextBlock Text="{Binding Employee.Valid}"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,12"/>
                        
                        <Button Content="Terminate"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Visibility="{Binding Employee.CanTerminate, Converter={StaticResource BoolToVisibilityConverter}}"
                                Command="{Binding GenerateTerminationCommand}"/>

                    </StackPanel>
                </materialDesign:Card>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

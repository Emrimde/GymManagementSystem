<UserControl x:Class="GymManagementSystem.WPF.Views.Auth.SetPasswordView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Auth"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             d:DesignHeight="450" d:DesignWidth="800" Background="{StaticResource BackgoundColor}">
    <Grid>

        <materialDesign:Card Padding="32"
                             MaxWidth="420"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             Background="#1E1E1E"
                             >

            <StackPanel>

                <TextBlock Text="Set new password"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Margin="0,0,0,8"/>

                <TextBlock Text="Enter a new password for your account"
                           Foreground="#B0B0B0"
                           Margin="0,0,0,24"/>

                <PasswordBox
                    materialDesign:HintAssist.Hint="New password"
                    materialDesign:HintAssist.Foreground="White"
                    materialDesign:HintAssist.IsFloating="True"
                    Foreground="White"
                    Background="Transparent"
                    CaretBrush="White"
                    Margin="0,0,0,16"
                    PasswordChanged="NewPasswordChanged"/>

                <PasswordBox
                    materialDesign:HintAssist.Hint="Confirm password"
                    materialDesign:HintAssist.Foreground="White"
                    materialDesign:HintAssist.IsFloating="True"
                    Foreground="White"
                    Background="Transparent"
                    CaretBrush="White"
                    Margin="0,0,0,28"
                    PasswordChanged="ConfirmPasswordChanged"/>

                <Button Content="Change password"
                        Command="{Binding SetPasswordCommand}"
                        Height="42"
                        FontWeight="SemiBold"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#9AAD00"
                        Foreground="White"/>
                
                <Button Content="Cancel"
                        Command="{Binding CancelCommand}"
                        Height="42"
                        Margin="0,10,0,0"
                        FontWeight="SemiBold"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        Background="#9AAD00"
                        Foreground="White"/>
            </StackPanel>
        </materialDesign:Card>

    </Grid>
</UserControl>

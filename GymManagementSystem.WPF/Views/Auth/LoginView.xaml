<UserControl x:Class="GymManagementSystem.WPF.Views.Auth.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <materialDesign:Card
            Width="600"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#2F3038"
            UniformCornerRadius="12"
            >

            <StackPanel>
                <TextBlock
                    FontSize="32"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryColor}"
                    HorizontalAlignment="Center">
                    <Run Text="Welcome in "/>
                    <Run Text="{DynamicResource GymName}" Foreground="{DynamicResource SecondColor}"/>
                    <Run Text=" System"/>
                </TextBlock>

                <TextBlock
                    Text="Login"
                    FontSize="16"
                    Margin="0,8,0,24"
                    HorizontalAlignment="Center"
                    Foreground="{DynamicResource PrimaryColor}"
                    Opacity="0.7"/>

                <TextBox
                    Style="{StaticResource MaterialDesignOutlinedTextBox}"
                    materialDesign:HintAssist.Hint="Username"
                    Text="{Binding Email}"
                    Margin="0,0,0,16"
                    Foreground="{StaticResource PrimaryColor}"
                    materialDesign:TextFieldAssist.DecorationVisibility="Hidden"/>

                <PasswordBox
                    PasswordChanged="PasswordBox_PasswordChanged"
                    Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                    materialDesign:HintAssist.Hint="Password"
                    Foreground="{StaticResource PrimaryColor}"
                    Margin="0,0,0,24"
                    
                    
                    
                    />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <!--<ColumnDefinition/--><!-->-->
                    </Grid.ColumnDefinitions>

                    <Button
                        Grid.Column="0"
                        Content="LOGIN"
                        Command="{Binding LoginCommand}"
                        Style="{StaticResource MaterialDesignNumericUpDownButtonsStyle}"
                        Background="{DynamicResource SecondColor}"
                        Foreground="Black"
                        Height="40"
                        Margin="0,0,8,0"/>

                    <!--<Button
                        Grid.Column="1"
                        Content="REGISTER"
                        Command="{Binding OpenRegisterViewCommand}"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Foreground="{DynamicResource SecondColor}"
                        BorderBrush="{DynamicResource SecondColor}"
                        Height="40"
                        Margin="8,0,0,0"/>-->
                </Grid>

            </StackPanel>
        </materialDesign:Card>
    </Grid>
</UserControl>

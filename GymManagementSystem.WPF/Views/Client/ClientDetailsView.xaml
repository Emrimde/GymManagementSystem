<UserControl x:Class="GymManagementSystem.WPF.Views.Client.ClientDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:conv="clr-namespace:GymManagementSystem.WPF.Converters"
             Background="{StaticResource BackgoundColor}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryColor}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,24,0,12"/>
        </Style>

        <Style x:Key="VerticalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>

        <Style x:Key="HorizontalItem" TargetType="FrameworkElement">
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <ContentControl Grid.Column="0"
                        Content="{Binding SidebarView}" />

        <ScrollViewer Grid.Column="1"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="32">

                <TextBlock FontSize="28"
                           FontWeight="Bold"
                           Margin="0,0,0,24">
                    <Run Text="{Binding Client.FirstName}"/>
                    <Run Text=" "/>
                    <Run Text="{Binding Client.LastName}"/>
                    <Run Text=" — details"/>
                </TextBlock>

                <materialDesign:Card Padding="24"
                                     UniformCornerRadius="16"
                                     materialDesign:ElevationAssist.Elevation="Dp4"
                                     Margin="0,0,0,32">

                    <StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="HomeMapMarker"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Address"/>
                                <TextBlock>
                                    <Run Text="{Binding Client.Street}"/>
                                    <Run Text=", "/>
                                    <Run Text="{Binding Client.City}"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="Phone"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Phone number"/>
                                <TextBlock Text="{Binding Client.PhoneNumber}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="CakeVariant"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Date of birth"/>
                                <TextBlock Text="{Binding Client.DateOfBirth}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="Counter"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Total visits"/>
                                <TextBlock Text="{Binding Client.TotalVisits}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Style="{StaticResource VerticalItem}">
                            <materialDesign:PackIcon Kind="CalendarCheck"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Last visit"/>
                                <TextBlock Text="{Binding Client.LastVisitDate}"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    Style="{StaticResource VerticalItem}"
                                    Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}">
                            <materialDesign:PackIcon Kind="CardAccountDetails"
                                                     Style="{StaticResource HorizontalItem}"/>
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold" Text="Membership valid"/>
                                <TextBlock Text="{Binding Client.Valid}"/>
                            </StackPanel>
                        </StackPanel>

                        <Separator Margin="0,12"/>

                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontWeight="Medium"
                                       Style="{StaticResource HorizontalItem}" Foreground="{StaticResource PrimaryColor}" FontSize="20"
                                       Text="{Binding ActiveMembershipName}"/>

                            <Button Content="Add Membership"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    Margin="0,0,12,0"
                                    Visibility="{Binding Client.IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                                    Command="{Binding OpenAddClientMembershipViewCommand}"
                                    CommandParameter="{Binding Client.Id}"/>

                            <Button Content="Terminate"
                                    Visibility="{Binding Client.CanTerminate, Converter={StaticResource BoolToVisibilityConverter}}"
                                    Command="{Binding CreateNewTerminationCommand}"/>
                        </StackPanel>

                    </StackPanel>
                </materialDesign:Card>

                <TextBlock Style="{StaticResource SectionTitle}"
                           Text="Actions" Foreground="{StaticResource PrimaryColor}"/>

                <WrapPanel Margin="0,0,0,32" ItemHeight="48">

                    <Button Width="240" Margin="0,0,12,12"
                            Content="Singular entry"
                            Visibility="{Binding Client.IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                            Command="{Binding RegisterVisitCommand}" />

                    <Button Width="240" Margin="0,0,12,12"
                            Content="Book classes"
                            Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding OpenAddClassBooking}" />

                    <Button Width="240" Margin="0,0,12,12"
                            Content="Register visit"
                            Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding RegisterVisitCommand}" />

                    <Button Width="240" Margin="0,0,12,12"
                            Content="Add Personal Training"
                            Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding OpenPersonalTrainingAddViewCommand}" />

                </WrapPanel>

                <TextBlock Style="{StaticResource SectionTitle}"
                           Text="History" Foreground="{StaticResource PrimaryColor}"/>

                <StackPanel Orientation="Horizontal">
                    <Button Width="240" Margin="0,0,12,0"
                            Content="Memberships history"
                            Command="{Binding OpenClientMembershipsHistory}" />

                    <Button Width="240" Margin="0,0,12,0"
                            Content="Visits history"
                            Command="{Binding OpenVisitsHistoryCommand}" />

                    <Button Width="240"
                            Content="All class bookings"
                            Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                            Command="{Binding OpenAllClientClassBookingCommand}" />
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

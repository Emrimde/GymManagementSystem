<UserControl x:Class="GymManagementSystem.WPF.Views.Client.ClientDetailsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Client"
             xmlns:conv="clr-namespace:GymManagementSystem.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" Content="{Binding SidebarView}"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="{DynamicResource PrimaryColor}">
                <Run Text="{Binding Client.FirstName}"/>
                <Run Text="{Binding Client.LastName}"/>
                <Run Text=": details"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Address: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                        <Run Text="{Binding Client.Street}"/>
                        <Run Text=", "/>
                        <Run Text="{Binding Client.City}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Phone number: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                        <Run Text="{Binding Client.PhoneNumber}"/>
         
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Date of birth: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20" Text="{Binding Client.DateOfBirth}"/>

                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Total visits: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20" Text="{Binding Client.TotalVisits}"/>

                </StackPanel><StackPanel Orientation="Horizontal">
                    <TextBlock Text="Last visit date: "  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20" Text="{Binding Client.LastVisitDate}"/>

                </StackPanel> 
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Text="Active Membership: " />
                    <TextBlock Foreground="{DynamicResource PrimaryColor}" VerticalAlignment="Center" Text="{Binding ActiveMembershipName}" />

                    <Button Content="Add Membership"
            Visibility="{Binding Client.IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}"
            Command="{Binding OpenAddClientMembershipViewCommand}" CommandParameter="{Binding Client.Id}" />
                   

                    <Button Content="Terminate"
            Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
            Command="{Binding CreateNewTerminationCommand}"  />
                   
                </StackPanel>
                <TextBlock Margin="0,50,0,0" HorizontalAlignment="Center" Text="Actions" Foreground="{DynamicResource PrimaryColor}" FontSize="25"/>

                <Button Width="200" Content="Book classes" Command="{Binding OpenAddClassBooking}" />
                <Button Content="Singular entry" Width="200"
                        Visibility="{Binding Client.IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                        Command="{Binding RegisterVisitCommand}"/>
                                        <Button Content="Register visit" Width="200"
                        Visibility="{Binding Client.IsActive, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{Binding RegisterVisitCommand}"  />
                    <TextBlock  HorizontalAlignment="Center" Text="History" Foreground="{DynamicResource PrimaryColor}" FontSize="25"/>
                
                    <Button Width="200" Content="Memberships history" Command="{Binding OpenClientMembershipsHistory}" />
                    <Button Width="200" Content="Visits history" Command="{Binding OpenVisitsHistoryCommand}" />
                    <Button Width="200" Content="All class bookings" Command="{Binding OpenAllClientClassBookingCommand}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

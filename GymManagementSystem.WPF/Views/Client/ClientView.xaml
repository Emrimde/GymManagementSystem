<UserControl x:Class="GymManagementSystem.WPF.Views.Client.ClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
             Background="{DynamicResource BackgoundColor}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#2F3038"
                Padding="8">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Gym Clients"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryColor}"
                           VerticalAlignment="Center"/>

                <Button Grid.Column="1"
        Content="ADD CLIENT"
        Command="{Binding OpenAddClientView}"
        Style="{StaticResource MaterialDesignRaisedButton}"
        Height="40"
        Padding="24,0"/>
            </Grid>

            <materialDesign:Card Grid.Row="1"
                                 Padding="16"
                                 Margin="0,0,0,16"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <ComboBox Width="160"
                              ItemsSource="{Binding StatusFilters}"
                              DisplayMemberPath="Label"
                              SelectedValuePath="Value"
                              SelectedValue="{Binding SelectedIsActive}"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              materialDesign:HintAssist.Hint="Status" Foreground="White"/>

                    <TextBox Width="240"
                             Margin="16,0,0,0"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}" Foreground="White"
                             materialDesign:HintAssist.Hint="Search clients">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding LoadClientsCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>

                    <Button Content="SEARCH"
                            Margin="16,0,0,0"
                            Height="40"
                            Command="{Binding LoadClientsCommand}"
                            Style="{StaticResource MaterialDesignOutlinedButton}"
                            />
                </StackPanel>
            </materialDesign:Card>

            <materialDesign:Card Grid.Row="2"
                                 Padding="0"
                                 Background="#2F3038"
                                 UniformCornerRadius="10">

                <DataGrid ItemsSource="{Binding Clients}"
          AutoGenerateColumns="False"
          CanUserAddRows="False"
          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="First name" Binding="{Binding FirstName}"/>
                        <DataGridTextColumn Header="Last name" Binding="{Binding LastName}"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding PhoneNumber}"/>

                        <DataGridTemplateColumn Header="Details" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Style="{StaticResource MaterialDesignIconButton}"
                   
                    Command="{Binding DataContext.OpenClientDetailsCommand,
                                      RelativeSource={RelativeSource AncestorType=DataGrid}}"
                    CommandParameter="{Binding Id}">
                                        <materialDesign:PackIcon Kind="InformationOutline"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                        <DataGridTemplateColumn Header="Edit" Width="80">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                   <Button Style="{StaticResource MaterialDesignIconButton}"
        Command="{Binding DataContext.OpenEditClientCommand,
                          RelativeSource={RelativeSource AncestorType=DataGrid}}"
        CommandParameter="{Binding Id}">
    <materialDesign:PackIcon Kind="Pencil"/>
</Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </materialDesign:Card>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0">

                <ItemsControl ItemsSource="{Binding VisiblePages}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>

                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding}"
                                    Margin="4"
                                    Command="{Binding DataContext.LoadClientsCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource MaterialDesignOutlinedButton}"
                                    />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

<UserControl x:Class="GymManagementSystem.WPF.Views.ClassBooking.ClassBookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.ClassBooking"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="#2F3038">
            <ContentControl Content="{Binding SidebarView}"/>
        </Border>

        <Grid Grid.Column="1">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Margin="32,24,32,16"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="{DynamicResource PrimaryColor}">
                <Run Text="{Binding Client.FullName}"/>
                <Run Text=" – Class bookings"/>
            </TextBlock>

            <materialDesign:Card Grid.Row="1"
                                 Margin="32,0,32,16"
                                 Padding="0"
                                 UniformCornerRadius="16"
                                 materialDesign:ElevationAssist.Elevation="Dp4">

                <DataGrid ItemsSource="{Binding ClassBookings}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          Style="{StaticResource MaterialDesignDataGrid}">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Name"
                                            Binding="{Binding Name}"/>

                        <DataGridTextColumn Header="Date"
                                            Binding="{Binding Date}"/>

                        <DataGridTextColumn Header="Start from"
                                            Binding="{Binding StartFrom}"/>

                        <DataGridTextColumn Header="Start to"
                                            Binding="{Binding StartTo}"/>

                        <DataGridTextColumn Header="Created at"
                                            Binding="{Binding CreatedAt}"/>

                        <DataGridTemplateColumn Header="Delete"
                                                Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Width="36"
                                            Height="36"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Command="{Binding DataContext.DeleteClassBookingCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                            CommandParameter="{Binding Id}">

                                        <materialDesign:PackIcon Kind="Delete"
                                                                 Width="20"
                                                                 Height="20"
                                                                 Foreground="#F44336"/>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>

                </DataGrid>

            </materialDesign:Card>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="32,0,32,24">

                <Button Content="Return"
                        Width="120"
                        Style="{StaticResource MaterialDesignOutlinedButton}"
                        Command="{Binding PreviousPageCommand}"/>

            </StackPanel>

        </Grid>
    </Grid>
</UserControl>

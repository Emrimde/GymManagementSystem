<UserControl x:Class="GymManagementSystem.WPF.Views.FormTextBox"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="40" d:DesignWidth="250">
    <Grid Background="{StaticResource BackgoundColor}">
        <TextBox x:Name="txtInput" VerticalContentAlignment="Center" FontWeight="Light" Panel.ZIndex="1" Background="Transparent" TextChanged="TextBox_TextChanged" />
        <TextBlock x:Name="placeholder"  Text="{Binding Placeholder}" VerticalAlignment="Center" Margin="5,0,0,0" Foreground="White"/>
    </Grid>
</UserControl>

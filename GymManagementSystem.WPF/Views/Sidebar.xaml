<UserControl x:Class="GymManagementSystem.WPF.Views.Sidebar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <StackPanel Background="#2B2B2B">
        <Button Command="{Binding OpenDashboardView}" Content="Dashboard" Margin="5"/>
        <Button Command="{Binding OpenClientView}" Content="Clients" Margin="5"/>
        <Button Command="{Binding OpenMembershipView}" Content="Memberships" Margin="5"/>
        <Button Content="Gym Classes" Command="{Binding OpenGymClassesView}" Margin="5"/>
        <Button Content="Staff" Command="{Binding OpenStaffView}" Margin="5"/>
        <Button Content="Logout" Command="{Binding LogoutCommand}" Margin="5"/>
    
       
        <Button Content="Settings" Command="{Binding OpenSettingsView}" Margin="5"/>
    </StackPanel>
</UserControl>

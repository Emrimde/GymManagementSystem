<UserControl x:Class="GymManagementSystem.WPF.Views.Contract.ContractDetails"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.WPF.Views.Contract"
             xmlns:converters="clr-namespace:GymManagementSystem.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Background="{DynamicResource BackgoundColor}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:ContractStatusToVisibility x:Key="ContractStatusVisibilityConverter"/>
        <converters:ContractStatusVisibilitySetSignedConverter x:Key ="ContractStatusVisibilitySetSigned"/>
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <ContentControl Grid.Column="0" Content="{Binding SidebarView}"/>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
                <RowDefinition Height="100"/>
            </Grid.RowDefinitions>
            <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30" Foreground="{DynamicResource PrimaryColor}">
            <Run Text="{Binding Contract.Client.FirstName}"/>
            <Run Text="{Binding Contract.Client.LastName}"/>
                 <Run Text=":"/>
            <Run Text="{Binding Contract.Name}"/>
            <Run Text=":contract"/>
            </TextBlock>
            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Phone number:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                    <Run Text="{Binding Contract.Client.PhoneNumber}"/>

                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Start Date:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                        <Run Text="{Binding Contract.StartDate}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="End Date:"  Foreground="{DynamicResource PrimaryColor}" FontSize="20"/>
                    <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource PrimaryColor}" FontSize="20">
                        <Run Text="{Binding Contract.EndDate}"/>
                    </TextBlock>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Button Content="PDF"
                        Width="70"
                        Height="35"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="10"
                        Command="{Binding GeneratePdfContractCommand}" Visibility="{Binding ContractStatus, Converter={StaticResource ContractStatusVisibilityConverter}}"
                        />
                    <Button Content="Set"
                        Width="70"
                        Height="35"
                        Background="#4CAF50"
                        Foreground="White"
                        FontSize="10"
                        Command="{Binding SetToSignedCommand}" Visibility="{Binding ContractStatus, Converter={StaticResource               ContractStatusVisibilitySetSigned}}"
                        />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

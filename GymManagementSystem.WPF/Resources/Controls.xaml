<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                     xmlns:local="clr-namespace:GymManagementSystem.WPF">
    

    <Style TargetType="Window">
        <Setter Property="WindowState" Value="Maximized"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="Background" Value="{DynamicResource BackgoundColor }"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource SecondColor}"/>
        <Setter Property="Foreground" Value="{DynamicResource BackgoundColor}"/>
        <Setter Property="TextElement.Foreground" Value="{DynamicResource BackgoundColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5"/>
    </Style>
    <Style TargetType="TextBlock">

        <Setter Property="FontSize" Value="17"/>
    </Style>
    <Style x:Key="SearchBox" TargetType="TextBox">

    </Style>
    
</ResourceDictionary>
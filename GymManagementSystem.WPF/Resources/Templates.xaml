<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:local="clr-namespace:GymManagementSystem.WPF"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:viewmodel="clr-namespace:GymManagementSystem.WPF.ViewModels"
                    xmlns:clientvm="clr-namespace:GymManagementSystem.WPF.ViewModels.Client"
                    xmlns:view="clr-namespace:GymManagementSystem.WPF.Views"
                    xmlns:clientview="clr-namespace:GymManagementSystem.WPF.Views.Client"
                    xmlns:membershipview="clr-namespace:GymManagementSystem.WPF.Views.Membership"
                    xmlns:membershipvm="clr-namespace:GymManagementSystem.WPF.ViewModels.Membership"
                    xmlns:contractvm="clr-namespace:GymManagementSystem.WPF.ViewModels.Contract"
                    xmlns:contractvview="clr-namespace:GymManagementSystem.WPF.Views.Contract"
                    xmlns:settingsvm="clr-namespace:GymManagementSystem.WPF.ViewModels.Settings"
                    xmlns:settingsview="clr-namespace:GymManagementSystem.WPF.Views.Settings"
                    xmlns:terminationvm="clr-namespace:GymManagementSystem.WPF.ViewModels.Termination"
                    xmlns:terminationview="clr-namespace:GymManagementSystem.WPF.Views.Termination"
                    xmlns:trainervm="clr-namespace:GymManagementSystem.WPF.ViewModels.Trainer"
                    xmlns:trainerview="clr-namespace:GymManagementSystem.WPF.Views.Trainer"
                    xmlns:gymclassvm="clr-namespace:GymManagementSystem.WPF.ViewModels.GymClass"
                    xmlns:gymclassview="clr-namespace:GymManagementSystem.WPF.Views.GymClass"
                    
                     xmlns:clientMembershipvm="clr-namespace:GymManagementSystem.WPF.ViewModels.ClientMembership"
 xmlns:clientMembershipview="clr-namespace:GymManagementSystem.WPF.Views.ClientMembership"
                    >
    
                    <DataTemplate DataType="{x:Type viewmodel:LoginViewModel}">
                        <view:LoginView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodel:RegisterViewModel}">
                        <view:RegisterView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodel:DashboardViewModel}">
                        <view:DashboardView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type clientvm:ClientAddViewModel}">
                        <clientview:ClientAddView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type clientvm:ClientUpdateViewModel}">
                        <clientview:ClientUpdateView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodel:ClientViewModel}">
                        <view:ClientView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type clientvm:ClientDetailsViewModel}">
                        <clientview:ClientDetailsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type membershipvm:MembershipViewModel}">
                        <membershipview:MembershipView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type membershipvm:MembershipAddViewModel}">
                        <membershipview:MembershipAddView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type membershipvm:MembershipEditViewModel}">
                        <membershipview:MembershipEditView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type contractvm:ContractViewModel}">
                        <contractvview:ContractView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type contractvm:ContractDetailsViewModel}">
                        <contractvview:ContractDetails/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type settingsvm:GeneralSettingsViewModel}">
                        <settingsview:GeneralSettingsView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type viewmodel:SidebarViewModel}">
                        <view:Sidebar/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type terminationvm:TerminationAddViewModel}">
                        <terminationview:TerminationAddView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type terminationvm:TerminationViewModel}">
                        <terminationview:TerminationView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type clientMembershipvm:ClientMembershipViewModel}">
                        <clientMembershipview:ClientMembershipView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type clientMembershipvm:ClientMembershipAddViewModel}">
                        <clientMembershipview:ClientMembershipAddView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type trainervm:TrainerViewModel}">
                        <trainerview:TrainerView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type trainervm:TrainerAddViewModel}">
                        <trainerview:TrainerAddView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type gymclassvm:GymClassViewModel}">
                        <gymclassview:GymClassView/>
                    </DataTemplate>
                    <DataTemplate DataType="{x:Type gymclassvm:GymClassAddViewModel}">
                        <gymclassview:GymClassAddView/>
                    </DataTemplate>
</ResourceDictionary>
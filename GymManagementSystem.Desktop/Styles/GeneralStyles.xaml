<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:GymManagementSystem.Desktop.ViewModel"
                    xmlns:v="clr-namespace:GymManagementSystem.Desktop.Views.UserControls"
                    xmlns:window="clr-namespace:GymManagementSystem.Desktop.Views">


    <SolidColorBrush x:Key="BackgoundColor" Color="#363740"/>
    <SolidColorBrush x:Key="PrimaryColor" Color="#EEEEEE"/>
    <SolidColorBrush x:Key="SecondColor" Color="#9AAD00"/>
    
    <Style TargetType="Window">
        <Setter Property="WindowState" Value="Maximized"/>
        <Setter Property="ResizeMode" Value="NoResize"/>
        <Setter Property="Background" Value="{StaticResource BackgoundColor }"/>
    </Style>
    <Style TargetType="Button">
        <Setter Property="Background" Value="{StaticResource SecondColor}"/>
        <Setter Property="Foreground" Value="{StaticResource BackgoundColor}"/>
        <Setter Property="TextElement.Foreground" Value="{StaticResource BackgoundColor}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="10,5"/>
        <Setter Property="Margin" Value="5"/>
    </Style>
    <Style TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="FontSize" Value="17"/>
    </Style>
    <!--
    <DataTemplate DataType="{x:Type vm:RegisterViewModel}">
        <v:RegisterView />
    </DataTemplate>
    
    <DataTemplate DataType="{x:Type vm:TestingViewModel}">
        <window:LoginWindow />
    </DataTemplate>
    -->

</ResourceDictionary>
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Desktop.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" >

    
        <StackPanel>
            <Button Command="" Content="Dashboard" Margin="5"/>
            <Button Command="{Binding OpenClientView}" Content="Clients" Margin="5"/>

<UserControl x:Class="GymManagementSystem.Desktop.Views.UserControls.DataGrid"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:GymManagementSystem.Desktop.Views.UserControls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <DataGrid ItemsSource="{Binding Items, RelativeSource={RelativeSource AncestorType=UserControl}}" 
AutoGenerateColumns="true"
Background="{StaticResource BackgoundColor}"
AlternatingRowBackground="#1E1E2E"
RowBackground="#2B2B3C"
Foreground="White"
BorderBrush="#3A3A4D"
BorderThickness="1"
HeadersVisibility="Column"
CanUserAddRows="False"
CanUserDeleteRows="False"
IsReadOnly="True"
Margin="10">

        
        </DataGrid>
</UserControl>
